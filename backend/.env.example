# Local development (Docker): both URLs point to the same instance
# Production (Vercel): DATABASE_URL = pooler URL, DIRECT_URL = direct connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/account_settings?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/account_settings?schema=public"
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
